<?xml version="1.0"?>
<ruleset name="Upkeepify Coding Standards">
    <description>WordPress Coding Standards for Upkeepify plugin</description>

    <!-- Scan upkeepify.php and includes/ folder -->
    <file>upkeepify.php</file>
    <file>includes/</file>

    <!-- Exclude vendor and tests from scanning -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/tests/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*.min.js</exclude-pattern>

    <!-- Command line arguments -->
    <arg name="basepath" value="."/>
    <arg name="colors"/>
    <arg value="sp"/>
    <arg name="extensions" value="php"/>

    <!-- Use WordPress Security ruleset only (formatting less critical than security) -->
    <rule ref="WordPress.Security"/>
    <rule ref="WordPress.DB"/>
    <rule ref="WordPress.WP.GlobalVariablesOverride"/>
    <rule ref="Universal.Operators.StrictComparisons"/>

    <!-- Suppress error_log warnings (used for security audit trails) -->
    <rule ref="WordPress.PHP.DevelopmentFunctions.error_log">
        <severity>0</severity>
    </rule>

    <!-- Minimum WordPress version for deprecated function checks -->
    <config name="minimum_supported_wp_version" value="5.0"/>
    <config name="testVersion" value="7.4-"/>

</ruleset>
